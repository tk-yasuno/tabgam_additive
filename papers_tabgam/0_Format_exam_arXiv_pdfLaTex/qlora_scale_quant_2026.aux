\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Training loss curves for five dataset scales (n=1,000 to 5,000). All models exhibit a characteristic three-phase pattern: rapid initial descent (epoch 0--0.4), plateau (1.0--2.0), and late-stage collapse (2.2--3.0). Larger datasets maintain consistently lower loss throughout training, with final loss decreasing from 0.869 (n=1,000) to 0.767 (n=5,000).}}{8}{figure.caption.17}\protected@file@percent }
\newlabel{fig:scale_train_loss}{{5}{8}{Training loss curves for five dataset scales (n=1,000 to 5,000). All models exhibit a characteristic three-phase pattern: rapid initial descent (epoch 0--0.4), plateau (1.0--2.0), and late-stage collapse (2.2--3.0). Larger datasets maintain consistently lower loss throughout training, with final loss decreasing from 0.869 (n=1,000) to 0.767 (n=5,000)}{figure.caption.17}{}}
