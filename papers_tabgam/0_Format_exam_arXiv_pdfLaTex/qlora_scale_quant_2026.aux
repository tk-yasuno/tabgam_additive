\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Multi-model performance comparison (F16 precision). Swallow-8B achieves the highest average score (2.820/3) and perfect-score rate (84\%), followed by ELYZA-JP-8B (2.700, 73\%). Qwen2.5-7B underperforms (2.420, 49\%) despite longest output length (677 chars), suggesting that multilingual pre-training dilutes Japanese technical vocabulary coverage.}}{10}{figure.caption.21}\protected@file@percent }
\newlabel{fig:multimodel_overview}{{7}{10}{Multi-model performance comparison (F16 precision). Swallow-8B achieves the highest average score (2.820/3) and perfect-score rate (84\%), followed by ELYZA-JP-8B (2.700, 73\%). Qwen2.5-7B underperforms (2.420, 49\%) despite longest output length (677 chars), suggesting that multilingual pre-training dilutes Japanese technical vocabulary coverage}{figure.caption.21}{}}
